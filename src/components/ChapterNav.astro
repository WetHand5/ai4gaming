---
interface Props {
  prev?: { title: string; href: string };
  next?: { title: string; href: string };
  parent?: { title: string; href: string };
}
const { prev, next, parent } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<nav class="chapter-nav">
  {parent && (
    <a href={`${base}/${parent.href.replace(/^\//, '')}`} class="nav-parent">
      <span class="nav-icon">◇</span>
      <span class="nav-label">UP TO</span>
      <span class="nav-title">{parent.title}</span>
    </a>
  )}

  <div class="nav-siblings">
    {prev ? (
      <a href={`${base}/${prev.href.replace(/^\//, '')}`} class="nav-link nav-prev">
        <span class="nav-arrow">←</span>
        <div class="nav-content">
          <span class="nav-direction">PREV</span>
          <span class="nav-text">{prev.title}</span>
        </div>
      </a>
    ) : (
      <div class="nav-link nav-prev nav-disabled">
        <span class="nav-arrow">←</span>
        <div class="nav-content">
          <span class="nav-direction">PREV</span>
          <span class="nav-text">—</span>
        </div>
      </div>
    )}

    {next ? (
      <a href={`${base}/${next.href.replace(/^\//, '')}`} class="nav-link nav-next">
        <div class="nav-content">
          <span class="nav-direction">NEXT</span>
          <span class="nav-text">{next.title}</span>
        </div>
        <span class="nav-arrow">→</span>
      </a>
    ) : (
      <div class="nav-link nav-next nav-disabled">
        <div class="nav-content">
          <span class="nav-direction">NEXT</span>
          <span class="nav-text">—</span>
        </div>
        <span class="nav-arrow">→</span>
      </div>
    )}
  </div>
</nav>