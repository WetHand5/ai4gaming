---
interface Props {
  title: string;
  type?: 'info' | 'warning' | 'tip' | 'code';
}
const { title, type = 'info' } = Astro.props;

const typeConfig: Record<string, { icon: string; label: string }> = {
  'info': { icon: 'ℹ', label: 'INFO' },
  'warning': { icon: '!', label: 'WARNING' },
  'tip': { icon: '★', label: 'TIP' },
  'code': { icon: '⬡', label: 'CODE' },
};

const config = typeConfig[type];
---

<div class:list={['content-block', `block--${type}`]}>
  <div class="block-header">
    <span class="block-icon">{config.icon}</span>
    <span class="block-label">{config.label}</span>
  </div>
  <div class="block-content">
    <h4 class="block-title">{title}</h4>
    <slot />
  </div>
</div>