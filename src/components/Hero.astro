---
interface Props {
  title: string;
  subtitle: string;
}
const { title, subtitle } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <h1 class="hero-title">{title}</h1>
  <p class="hero-subtitle">{subtitle}</p>
  <div class="hero-actions">
    <a href={`${base}/search-algorithms/`} class="hero-btn">Start Learning</a>
    <a href={`${base}/roadmap/`} class="hero-btn hero-btn--secondary">Roadmap</a>
  </div>
</section>
